---
import AppLayout from '@/layouts/AppLayout.astro';
import Shell from '@/components/shell/Shell.astro';
import { Card, CardContent, CardDescription, CardHeader, CardTitle } from '@/components/ui/card';

if (!Astro.locals.user) {
  return Astro.redirect('/login');
}
---

<AppLayout title="Gym | Workouts">
  <Shell title="Workouts" subtitle="Routines, logs, and PRs">
    <div class="grid gap-4 md:grid-cols-2">
      <Card>
        <CardHeader>
          <CardTitle>Log a workout</CardTitle>
          <CardDescription>Coming next: routine builder + paste import.</CardDescription>
        </CardHeader>
        <CardContent>
          <p class="text-sm text-muted-foreground">Scaffold page.</p>
        </CardContent>
      </Card>
      <Card>
        <CardHeader>
          <CardTitle>Recent sessions</CardTitle>
          <CardDescription>Charts and progression.</CardDescription>
        </CardHeader>
        <CardContent>
          <p class="text-sm text-muted-foreground">Scaffold page.</p>
        </CardContent>
      </Card>
    </div>
  </Shell>
</AppLayout>
