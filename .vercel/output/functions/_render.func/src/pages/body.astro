---
import AppLayout from '@/layouts/AppLayout.astro';
import Shell from '@/components/shell/Shell.astro';
import { Card, CardContent, CardDescription, CardHeader, CardTitle } from '@/components/ui/card';
import { Button } from '@/components/ui/button';
import { Input } from '@/components/ui/input';
import { Label } from '@/components/ui/label';
import { Separator } from '@/components/ui/separator';
import { BodyChart } from '@/components/body/BodyChart';
import { calculateBMI } from '@/lib/body/bmi';
import { getBodyWeightSeries, listBodyMetrics } from '@/lib/body/queries';
import { formatNumber } from '@/lib/number';
import { startOfDay, toISODate } from '@/lib/date';
import { prisma } from '@/lib/db';

if (!Astro.locals.user) {
  return Astro.redirect('/login');
}

const user = Astro.locals.user;
const error = Astro.url.searchParams.get('error');

const profile = await prisma.userProfile.findUnique({
  where: { userId: user.id },
  select: { heightCm: true }
}).catch(() => null);

let metrics: Awaited<ReturnType<typeof listBodyMetrics>> = [];
let series: Awaited<ReturnType<typeof getBodyWeightSeries>> = [];

try {
  [metrics, series] = await Promise.all([listBodyMetrics(user.id, 30), getBodyWeightSeries(user.id, 30)]);
} catch {
  // If DB isn't configured yet, the page should still render.
  metrics = [];
  series = [];
}

const today = startOfDay(new Date());
const latest = metrics[0] ?? null;

const bmi = calculateBMI(latest?.weightKg ?? null, profile?.heightCm ?? null);

const points = series
  .filter((p) => typeof p.weightKg === 'number')
  .map((p) => ({ label: toISODate(p.date).slice(5), kg: p.weightKg as number }));
---

<AppLayout title="Gym | Body">
  <Shell title="Body" subtitle="Weight, measurements, and trends">
    <div class="grid gap-4 lg:grid-cols-12">
      <Card className="glass lg:col-span-5">
        <CardHeader>
          <CardTitle>Log metrics</CardTitle>
          <CardDescription>One entry per day (updates if it already exists).</CardDescription>
        </CardHeader>
        <CardContent>
          {error ? <p class="mb-3 text-sm text-destructive">{error}</p> : null}
          <form method="post" action="/api/body/upsert" class="grid gap-4">
            <div class="grid gap-2">
              <Label htmlFor="date">Date</Label>
              <Input id="date" name="date" type="date" required defaultValue={toISODate(today)} />
            </div>
            <div class="grid grid-cols-2 gap-3">
              <div class="grid gap-2">
                <Label htmlFor="weightKg">Weight (kg)</Label>
                <Input id="weightKg" name="weightKg" inputMode="decimal" placeholder="81.2" />
              </div>
              <div class="grid gap-2">
                <Label htmlFor="bodyFatPct">Body fat (%)</Label>
                <Input id="bodyFatPct" name="bodyFatPct" inputMode="decimal" placeholder="18.5" />
              </div>
            </div>

            <Separator />

            <div class="grid grid-cols-2 gap-3">
              <div class="grid gap-2">
                <Label htmlFor="armsCm">Arms (cm)</Label>
                <Input id="armsCm" name="armsCm" inputMode="decimal" />
              </div>
              <div class="grid gap-2">
                <Label htmlFor="chestCm">Chest (cm)</Label>
                <Input id="chestCm" name="chestCm" inputMode="decimal" />
              </div>
              <div class="grid gap-2">
                <Label htmlFor="waistCm">Waist (cm)</Label>
                <Input id="waistCm" name="waistCm" inputMode="decimal" />
              </div>
              <div class="grid gap-2">
                <Label htmlFor="legsCm">Legs (cm)</Label>
                <Input id="legsCm" name="legsCm" inputMode="decimal" />
              </div>
            </div>

            <div class="grid gap-2">
              <Label htmlFor="notes">Notes</Label>
              <Input id="notes" name="notes" type="text" placeholder="Optional" />
            </div>

            <Button type="submit">Save</Button>
          </form>
        </CardContent>
      </Card>

      <Card className="glass lg:col-span-7">
        <CardHeader>
          <CardTitle>Trends</CardTitle>
          <CardDescription>Last 30 days</CardDescription>
        </CardHeader>
        <CardContent className="h-[280px]">
          <BodyChart client:load points={points} />
        </CardContent>
      </Card>
    </div>

    <div class="mt-4 grid gap-4 lg:grid-cols-12">
      <Card className="glass lg:col-span-4">
        <CardHeader>
          <CardTitle>Latest</CardTitle>
          <CardDescription>Your most recent entry</CardDescription>
        </CardHeader>
        <CardContent>
          {latest ? (
            <div class="grid gap-2 text-sm">
              <p class="text-muted-foreground">{toISODate(latest.date)}</p>
              <p>
                <span class="text-muted-foreground">Weight:</span> {latest.weightKg != null ? `${formatNumber(latest.weightKg, { maximumFractionDigits: 1 })} kg` : '—'}
              </p>
              <p>
                <span class="text-muted-foreground">Body fat:</span> {latest.bodyFatPct != null ? `${formatNumber(latest.bodyFatPct, { maximumFractionDigits: 1 })}%` : '—'}
              </p>
              <p>
                <span class="text-muted-foreground">BMI:</span> {bmi != null ? formatNumber(bmi, { maximumFractionDigits: 1 }) : '—'}
                <span class="text-xs text-muted-foreground"> (height will be added in Settings)</span>
              </p>
            </div>
          ) : (
            <p class="text-sm text-muted-foreground">No metrics yet.</p>
          )}
        </CardContent>
      </Card>

      <Card className="glass lg:col-span-8">
        <CardHeader>
          <CardTitle>History</CardTitle>
          <CardDescription>Most recent 30 entries</CardDescription>
        </CardHeader>
        <CardContent>
          {metrics.length ? (
            <div class="grid gap-2">
              {metrics.map((m) => (
                <div class="flex items-center justify-between gap-3 rounded-lg border border-border/60 bg-background/30 px-3 py-2">
                  <div class="min-w-0">
                    <p class="text-sm font-medium">{toISODate(m.date)}</p>
                    <p class="text-xs text-muted-foreground">
                      {m.weightKg != null ? `${formatNumber(m.weightKg, { maximumFractionDigits: 1 })} kg` : '—'}
                      {m.bodyFatPct != null ? ` • ${formatNumber(m.bodyFatPct, { maximumFractionDigits: 1 })}%` : ''}
                    </p>
                  </div>
                  <form method="post" action="/api/body/delete">
                    <input type="hidden" name="date" value={toISODate(m.date)} />
                    <Button type="submit" variant="ghost">Delete</Button>
                  </form>
                </div>
              ))}
            </div>
          ) : (
            <p class="text-sm text-muted-foreground">No history yet.</p>
          )}
        </CardContent>
      </Card>
    </div>
  </Shell>
</AppLayout>
