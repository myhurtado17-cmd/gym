---
import AppLayout from '@/layouts/AppLayout.astro';
import Shell from '@/components/shell/Shell.astro';
import { Card, CardContent, CardDescription, CardHeader, CardTitle } from '@/components/ui/card';

if (!Astro.locals.user) {
  return Astro.redirect('/login');
}
---

<AppLayout title="Gym | Goals">
  <Shell title="Goals" subtitle="Targets and milestones">
    <Card>
      <CardHeader>
        <CardTitle>Goal tracking</CardTitle>
        <CardDescription>Weight goal, macro goal, strength goals.</CardDescription>
      </CardHeader>
      <CardContent>
        <p class="text-sm text-muted-foreground">Scaffold page.</p>
      </CardContent>
    </Card>
  </Shell>
</AppLayout>
