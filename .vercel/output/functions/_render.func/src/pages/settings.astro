---
import AppLayout from '@/layouts/AppLayout.astro';
import Shell from '@/components/shell/Shell.astro';
import { Card, CardContent, CardDescription, CardHeader, CardTitle } from '@/components/ui/card';

if (!Astro.locals.user) {
  return Astro.redirect('/login');
}
---

<AppLayout title="Gym | Settings">
  <Shell title="Settings" subtitle="Profile and preferences">
    <Card>
      <CardHeader>
        <CardTitle>Profile</CardTitle>
        <CardDescription>Name, height, goals, avatar.</CardDescription>
      </CardHeader>
      <CardContent>
        <p class="text-sm text-muted-foreground">Scaffold page.</p>
      </CardContent>
    </Card>
  </Shell>
</AppLayout>
