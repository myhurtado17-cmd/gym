---
import AppLayout from '@/layouts/AppLayout.astro';
import Shell from '@/components/shell/Shell.astro';
import { Card, CardContent, CardDescription, CardHeader, CardTitle } from '@/components/ui/card';
import { Button } from '@/components/ui/button';
import { Input } from '@/components/ui/input';
import { Separator } from '@/components/ui/separator';
import CsrfInput from '@/components/security/CsrfInput.astro';

import { getNutritionDay, listNutritionDays } from '@/lib/nutrition/queries';
import { parseISODate, startOfDay, toISODate } from '@/lib/date';
import { formatNumber } from '@/lib/number';
import { getActiveNutritionTargets } from '@/lib/nutrition/goals';
import ProgressBar from '@/components/nutrition/ProgressBar.astro';
import { CaloriesChart } from '@/components/nutrition/CaloriesChart';
import { getCaloriesSeries } from '@/lib/nutrition/trends';

if (!Astro.locals.user) return Astro.redirect('/login');

const userId = Astro.locals.user.id;
const error = Astro.url.searchParams.get('error');
const dateParam = Astro.url.searchParams.get('date');
const selectedDate = startOfDay(dateParam ? (parseISODate(dateParam) ?? new Date()) : new Date());

const [day, recentDays, caloriesSeries] = await Promise.all([
  getNutritionDay(userId, selectedDate).catch(() => null),
  listNutritionDays(userId, 14).catch(() => []),
  getCaloriesSeries(userId, 7).catch(() => [])
]);

const targets = await getActiveNutritionTargets(userId).catch(() => ({
  calories: null,
  proteinG: null,
  carbsG: null,
  fatG: null
}));

const totals = day
  ? {
      calories: day.calories,
      proteinG: day.proteinG,
      carbsG: day.carbsG,
      fatG: day.fatG
    }
  : { calories: 0, proteinG: 0, carbsG: 0, fatG: 0 };

const calPoints = caloriesSeries.map((p) => ({
  label: toISODate(p.date).slice(5),
  calories: p.calories
}));
---

<AppLayout title="GymTracker | Nutrición">
  <Shell title="Nutrición" subtitle="Calorías y macronutrientes">
    <div class="grid gap-4 lg:grid-cols-12">
      <Card className="glass lg:col-span-7">
        <CardHeader>
          <CardTitle>Registro diario</CardTitle>
          <CardDescription>Controla comidas y macros de una fecha específica.</CardDescription>
        </CardHeader>
        <CardContent>
          {error ? <p class="mb-3 text-sm text-destructive">{error}</p> : null}

          <form method="get" action="/nutrition" class="flex flex-col gap-2 sm:flex-row sm:items-end">
            <div class="grid flex-1 gap-1">
              <label class="text-xs text-muted-foreground" for="date">Fecha</label>
              <Input id="date" name="date" type="date" required defaultValue={toISODate(selectedDate)} />
            </div>
            <Button type="submit" variant="outline">Ir</Button>
          </form>

          <Separator className="my-4" />

          <div class="grid gap-3 sm:grid-cols-4">
            <div class="rounded-lg border border-border/60 bg-background/30 px-3 py-2">
              <p class="text-xs text-muted-foreground">Calorías</p>
              <p class="text-sm font-semibold">{formatNumber(totals.calories)}</p>
            </div>
            <div class="rounded-lg border border-border/60 bg-background/30 px-3 py-2">
              <p class="text-xs text-muted-foreground">Proteína (g)</p>
              <p class="text-sm font-semibold">{formatNumber(totals.proteinG)}</p>
            </div>
            <div class="rounded-lg border border-border/60 bg-background/30 px-3 py-2">
              <p class="text-xs text-muted-foreground">Carbos (g)</p>
              <p class="text-sm font-semibold">{formatNumber(totals.carbsG)}</p>
            </div>
            <div class="rounded-lg border border-border/60 bg-background/30 px-3 py-2">
              <p class="text-xs text-muted-foreground">Grasa (g)</p>
              <p class="text-sm font-semibold">{formatNumber(totals.fatG)}</p>
            </div>
          </div>

          <div class="mt-4 grid gap-3">
            <ProgressBar label="Calorías" value={totals.calories} target={targets.calories} unit="kcal" />
            <ProgressBar label="Proteína" value={totals.proteinG} target={targets.proteinG} unit="g" />
            <ProgressBar label="Carbos" value={totals.carbsG} target={targets.carbsG} unit="g" />
            <ProgressBar label="Grasa" value={totals.fatG} target={targets.fatG} unit="g" />
          </div>

          <Separator className="my-4" />

          <Card className="border-border/60 bg-background/10">
            <CardHeader>
              <CardTitle>Añadir entrada</CardTitle>
              <CardDescription>Una fila por comida o alimento.</CardDescription>
            </CardHeader>
            <CardContent>
              <form method="post" action="/api/nutrition/entry/add" class="grid gap-3">
                <CsrfInput />
                <input type="hidden" name="date" value={toISODate(selectedDate)} />
                <div class="grid gap-1">
                  <label class="text-xs text-muted-foreground" for="mealName">Comida / Ítem</label>
                  <Input id="mealName" name="mealName" placeholder="Pollo + arroz" required />
                </div>
                <div class="grid grid-cols-2 gap-3 sm:grid-cols-4">
                  <div class="grid gap-1">
                    <label class="text-xs text-muted-foreground" for="calories">Calorías</label>
                    <Input id="calories" name="calories" inputMode="numeric" placeholder="650" required />
                  </div>
                  <div class="grid gap-1">
                    <label class="text-xs text-muted-foreground" for="proteinG">Proteína</label>
                    <Input id="proteinG" name="proteinG" inputMode="numeric" placeholder="45" required />
                  </div>
                  <div class="grid gap-1">
                    <label class="text-xs text-muted-foreground" for="carbsG">Carbos</label>
                    <Input id="carbsG" name="carbsG" inputMode="numeric" placeholder="70" required />
                  </div>
                  <div class="grid gap-1">
                    <label class="text-xs text-muted-foreground" for="fatG">Grasa</label>
                    <Input id="fatG" name="fatG" inputMode="numeric" placeholder="18" required />
                  </div>
                </div>
                <div class="grid gap-1">
                  <label class="text-xs text-muted-foreground" for="notes">Notas</label>
                  <Input id="notes" name="notes" placeholder="opcional" />
                </div>
                <div class="flex justify-end">
                  <Button type="submit" variant="secondary">Añadir</Button>
                </div>
              </form>
            </CardContent>
          </Card>

          <Separator className="my-4" />

          <div class="grid gap-2">
            <p class="text-sm font-semibold">Entradas</p>
            {day?.entries?.length ? (
              <div class="grid gap-2">
                {day.entries.map((e) => (
                  <div key={e.id} class="flex items-start justify-between gap-3 rounded-lg border border-border/60 bg-background/30 px-3 py-2">
                    <div class="min-w-0">
                      <p class="truncate text-sm font-medium">{e.mealName}</p>
                      <p class="text-xs text-muted-foreground">
                        {e.calories} kcal · P {e.proteinG} · C {e.carbsG} · G {e.fatG}
                        {e.notes ? ` · ${e.notes}` : ''}
                      </p>
                    </div>
                    <form method="post" action="/api/nutrition/entry/delete">
                      <CsrfInput />
                      <input type="hidden" name="entryId" value={e.id} />
                      <Button type="submit" variant="ghost" size="sm">Eliminar</Button>
                    </form>
                  </div>
                ))}
              </div>
            ) : (
              <p class="text-sm text-muted-foreground">Sin entradas para este día.</p>
            )}
          </div>
        </CardContent>
      </Card>

      <Card className="lg:col-span-5">
        <CardHeader>
          <CardTitle>Días recientes</CardTitle>
          <CardDescription>Acceso rápido y chequeo de consistencia.</CardDescription>
        </CardHeader>
        <CardContent>
          <div class="mb-4">
            <p class="text-sm font-semibold">Calorías 7 días</p>
            <div class="mt-2 h-[160px]">
              <CaloriesChart client:load points={calPoints} />
            </div>
          </div>
          {recentDays.length ? (
            <div class="grid gap-2">
              {recentDays.map((d) => (
                <a
                  key={d.id}
                  href={`/nutrition?date=${encodeURIComponent(toISODate(d.date))}`}
                  class="flex items-center justify-between gap-3 rounded-lg border border-border/60 bg-background/30 px-3 py-2 text-sm hover:bg-accent"
                >
                  <div class="min-w-0">
                    <p class="truncate font-medium">{toISODate(d.date)}</p>
                    <p class="text-xs text-muted-foreground">{d._count.entries} entradas</p>
                  </div>
                  <p class="text-xs text-muted-foreground">{d.calories} kcal</p>
                </a>
              ))}
            </div>
          ) : (
            <p class="text-sm text-muted-foreground">Sin días registrados aún.</p>
          )}
          <div class="mt-4">
            <Button asChild variant="outline" className="w-full">
              <a href="/nutrition/import">Importar</a>
            </Button>
          </div>
        </CardContent>
      </Card>
    </div>
  </Shell>
</AppLayout>
