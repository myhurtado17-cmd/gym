---
import AppLayout from '@/layouts/AppLayout.astro';
import Shell from '@/components/shell/Shell.astro';
import { Card, CardContent, CardDescription, CardHeader, CardTitle } from '@/components/ui/card';

if (!Astro.locals.user) {
  return Astro.redirect('/login');
}
---

<AppLayout title="Gym | Nutrition">
  <Shell title="Nutrition" subtitle="Calories and macros">
    <div class="grid gap-4 md:grid-cols-2">
      <Card>
        <CardHeader>
          <CardTitle>Today</CardTitle>
          <CardDescription>Macro progress and meals.</CardDescription>
        </CardHeader>
        <CardContent>
          <p class="text-sm text-muted-foreground">Scaffold page.</p>
        </CardContent>
      </Card>
      <Card>
        <CardHeader>
          <CardTitle>Import diet plan</CardTitle>
          <CardDescription>Paste diet plans and auto-structure by meal.</CardDescription>
        </CardHeader>
        <CardContent>
          <p class="text-sm text-muted-foreground">Scaffold page.</p>
        </CardContent>
      </Card>
    </div>
  </Shell>
</AppLayout>
