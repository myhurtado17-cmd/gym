---
import AppLayout from '@/layouts/AppLayout.astro';
import { Card, CardContent, CardDescription, CardHeader, CardTitle } from '@/components/ui/card';
import { Button } from '@/components/ui/button';
import { Input } from '@/components/ui/input';
import { Label } from '@/components/ui/label';
import CsrfInput from '@/components/security/CsrfInput.astro';

const token = Astro.url.searchParams.get('token');
const error = Astro.url.searchParams.get('error');
---

<AppLayout title="GymTracker | Nueva contraseña">
  <main class="relative">
    <div class="pointer-events-none absolute inset-0 -z-10 overflow-hidden">
      <div class="absolute -top-48 left-1/2 h-[620px] w-[620px] -translate-x-1/2 rounded-full bg-gradient-to-tr from-violet-500/20 via-sky-500/20 to-emerald-500/20 blur-3xl" />
    </div>

    <div class="mx-auto grid min-h-dvh max-w-md place-items-center px-4 py-10">
      <Card class="glass w-full">
        <CardHeader>
          <CardTitle class="text-2xl">Nueva contraseña</CardTitle>
          <CardDescription>Elige una contraseña segura.</CardDescription>
        </CardHeader>
        <CardContent>
          {error === 'expired' ? <p class="mb-4 text-sm text-destructive">Enlace expirado o inválido.</p> : null}
          {error === 'invalid' ? <p class="mb-4 text-sm text-destructive">Datos inválidos.</p> : null}
          {!token ? (
            <p class="text-sm text-muted-foreground">Enlace inválido. Solicita un nuevo restablecimiento.</p>
          ) : (
            <form method="post" action="/api/auth/reset-password" class="grid gap-4">
              <CsrfInput />
              <input type="hidden" name="token" value={token} />
              <div class="grid gap-2">
                <Label htmlFor="password">Nueva contraseña</Label>
                <Input id="password" name="password" type="password" autoComplete="new-password" required />
                <p class="text-xs text-muted-foreground">Mínimo 8 caracteres.</p>
              </div>
              <Button type="submit">Restablecer contraseña</Button>
            </form>
          )}
          <div class="mt-4">
            <p class="text-sm text-muted-foreground">
              <a class="underline underline-offset-4 hover:text-foreground" href="/login">Volver a inicio de sesión</a>
            </p>
          </div>
        </CardContent>
      </Card>
    </div>
  </main>
</AppLayout>
