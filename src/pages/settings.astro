---
import AppLayout from '@/layouts/AppLayout.astro';
import Shell from '@/components/shell/Shell.astro';
import { Card, CardContent, CardDescription, CardHeader, CardTitle } from '@/components/ui/card';

if (!Astro.locals.user) {
  return Astro.redirect('/login');
}
---

<AppLayout title="GymTracker | Ajustes">
  <Shell title="Ajustes" subtitle="Perfil y preferencias">
    <Card>
      <CardHeader>
        <CardTitle>Perfil</CardTitle>
        <CardDescription>Nombre, altura, metas, avatar.</CardDescription>
      </CardHeader>
      <CardContent>
        <p class="text-sm text-muted-foreground">Página en construcción.</p>
      </CardContent>
    </Card>
  </Shell>
</AppLayout>
