---
import AppLayout from '@/layouts/AppLayout.astro';
import { Card, CardContent, CardDescription, CardHeader, CardTitle } from '@/components/ui/card';
import { Button } from '@/components/ui/button';
import { Input } from '@/components/ui/input';
import { Label } from '@/components/ui/label';
import CsrfInput from '@/components/security/CsrfInput.astro';

const error = Astro.url.searchParams.get('error');
const reset = Astro.url.searchParams.get('reset');
const deleted = Astro.url.searchParams.get('deleted');
---

<AppLayout title="GymTracker | Iniciar sesión">
  <main class="relative">
    <div class="pointer-events-none absolute inset-0 -z-10 overflow-hidden">
      <div class="absolute -top-48 left-1/2 h-[620px] w-[620px] -translate-x-1/2 rounded-full bg-gradient-to-tr from-violet-500/20 via-sky-500/20 to-emerald-500/20 blur-3xl" />
    </div>

    <div class="mx-auto grid min-h-dvh max-w-md place-items-center px-4 py-10">
      <Card className="glass w-full">
        <CardHeader>
          <CardTitle className="text-2xl">GymTracker</CardTitle>
          <CardDescription>Inicia sesión para continuar.</CardDescription>
        </CardHeader>
        <CardContent>
          {reset ? <p class="mb-4 rounded-lg border border-green-500/30 bg-green-500/10 px-3 py-2 text-sm text-green-600 dark:text-green-400">Contraseña restablecida correctamente.</p> : null}
          {deleted ? <p class="mb-4 rounded-lg border border-green-500/30 bg-green-500/10 px-3 py-2 text-sm text-green-600 dark:text-green-400">Cuenta eliminada.</p> : null}
          {error ? <p class="mb-4 text-sm text-destructive">{error}</p> : null}
          <form method="post" action="/api/auth/login" class="grid gap-4">
            <CsrfInput />
            <div class="grid gap-2">
              <Label htmlFor="email">Correo electrónico</Label>
              <Input id="email" name="email" type="email" autoComplete="email" required />
            </div>
            <div class="grid gap-2">
              <Label htmlFor="password">Contraseña</Label>
              <Input id="password" name="password" type="password" autoComplete="current-password" required />
            </div>
            <Button type="submit">Iniciar sesión</Button>
            <div class="flex items-center justify-between text-sm">
              <a class="text-muted-foreground underline underline-offset-4 hover:text-foreground" href="/forgot-password">¿Olvidaste tu contraseña?</a>
              <span class="text-muted-foreground">
                ¿Sin cuenta?{' '}
                <a class="underline underline-offset-4 hover:text-foreground" href="/register">Crea una</a>
              </span>
            </div>
          </form>
        </CardContent>
      </Card>
    </div>
  </main>
</AppLayout>
