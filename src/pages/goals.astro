---
import AppLayout from '@/layouts/AppLayout.astro';
import Shell from '@/components/shell/Shell.astro';
import { Card, CardContent, CardDescription, CardHeader, CardTitle } from '@/components/ui/card';
import { Button } from '@/components/ui/button';
import { Input } from '@/components/ui/input';
import { Separator } from '@/components/ui/separator';
import CsrfInput from '@/components/security/CsrfInput.astro';
import { listGoals } from '@/lib/goals/queries';
import { toISODate, startOfDay } from '@/lib/date';
import { formatNumber } from '@/lib/number';
import { prisma } from '@/lib/db';

if (!Astro.locals.user) {
  return Astro.redirect('/login');
}

const userId = Astro.locals.user.id;
const error = Astro.url.searchParams.get('error');

const goals = await listGoals(userId, 50).catch(() => []);
const today = startOfDay(new Date());

const latestWeight = await prisma.bodyMetric.findFirst({
  where: { userId, weightKg: { not: null } },
  orderBy: { date: 'desc' },
  select: { weightKg: true }
}).catch(() => null);
---

<AppLayout title="GymTracker | Metas">
  <Shell title="Metas" subtitle="Objetivos e hitos">
    <div class="grid gap-4 lg:grid-cols-12">
      <Card className="glass lg:col-span-6">
        <CardHeader>
          <CardTitle>Crear meta</CardTitle>
          <CardDescription>
            Metas de nutrición: usa <code class="font-mono">CALORIES</code> (kcal) y <code class="font-mono">MACROS</code> con unidad
            <code class="font-mono">protein</code>/<code class="font-mono">carbs</code>/<code class="font-mono">fat</code>.
          </CardDescription>
        </CardHeader>
        <CardContent>
          {error ? <p class="mb-3 text-sm text-destructive">{error}</p> : null}
          <form method="post" action="/api/goals/upsert" class="grid gap-3">
            <CsrfInput />
            <div class="grid gap-1">
              <label class="text-xs text-muted-foreground" for="type">Tipo</label>
              <select
                id="type"
                name="type"
                class="h-10 w-full rounded-md border border-input bg-background px-3 text-sm shadow-sm focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2 focus-visible:ring-offset-background"
                required
              >
                <option value="WEIGHT">PESO</option>
                <option value="BODY_FAT">GRASA CORPORAL</option>
                <option value="CALORIES">CALORÍAS</option>
                <option value="MACROS">MACROS</option>
                <option value="STRENGTH">FUERZA</option>
              </select>
            </div>
            <div class="grid gap-1">
              <label class="text-xs text-muted-foreground" for="title">Título</label>
              <Input id="title" name="title" placeholder="Definición: 2300 kcal" required />
            </div>
            <div class="grid grid-cols-2 gap-3">
              <div class="grid gap-1">
                <label class="text-xs text-muted-foreground" for="targetValue">Valor objetivo</label>
                <Input id="targetValue" name="targetValue" placeholder="2300" />
              </div>
              <div class="grid gap-1">
                <label class="text-xs text-muted-foreground" for="unit">Unidad (opcional)</label>
                <Input id="unit" name="unit" placeholder="kcal / protein / kg" />
              </div>
            </div>
            <div class="grid grid-cols-2 gap-3">
              <div class="grid gap-1">
                <label class="text-xs text-muted-foreground" for="startsAt">Inicio</label>
                <Input id="startsAt" name="startsAt" type="date" required defaultValue={toISODate(today)} />
              </div>
              <div class="grid gap-1">
                <label class="text-xs text-muted-foreground" for="endsAt">Fin (opcional)</label>
                <Input id="endsAt" name="endsAt" type="date" />
              </div>
            </div>
            <div class="flex justify-end">
              <Button type="submit" variant="secondary">Guardar meta</Button>
            </div>
          </form>
        </CardContent>
      </Card>

      <Card className="lg:col-span-6">
        <CardHeader>
          <CardTitle>Tus metas</CardTitle>
          <CardDescription>Más recientes primero.</CardDescription>
        </CardHeader>
        <CardContent>
          {goals.length ? (
            <div class="grid gap-3">
              {goals.map((g) => (
                <div key={g.id} class="rounded-lg border border-border/60 bg-background/30 p-3">
                  <div class="flex items-start justify-between gap-3">
                    <div class="min-w-0">
                      <p class="truncate text-sm font-semibold">{g.title}</p>
                      <p class="text-xs text-muted-foreground">
                        {g.type}
                        {g.targetValue != null ? ` · objetivo ${formatNumber(g.targetValue, { maximumFractionDigits: 1 })}` : ''}
                        {g.unit ? ` ${g.unit}` : ''}
                        {` · ${toISODate(g.startsAt)}`}
                        {g.endsAt ? ` → ${toISODate(g.endsAt)}` : ''}
                      </p>
                    </div>
                    <form method="post" action="/api/goals/delete">
                      <CsrfInput />
                      <input type="hidden" name="id" value={g.id} />
                      <Button type="submit" variant="ghost" size="sm">Eliminar</Button>
                    </form>
                  </div>

                  <Separator className="my-3" />

                  <form method="post" action="/api/goals/upsert" class="grid gap-2 sm:grid-cols-2">
                    <CsrfInput />
                    <input type="hidden" name="id" value={g.id} />
                    <input type="hidden" name="type" value={g.type} />
                    <div class="grid gap-1 sm:col-span-2">
                      <label class="text-xs text-muted-foreground" for={`title-${g.id}`}>Título</label>
                      <Input id={`title-${g.id}`} name="title" required defaultValue={g.title} />
                    </div>
                    <div class="grid gap-1">
                      <label class="text-xs text-muted-foreground" for={`target-${g.id}`}>Objetivo</label>
                      <Input id={`target-${g.id}`} name="targetValue" defaultValue={g.targetValue ?? ''} />
                    </div>
                    <div class="grid gap-1">
                      <label class="text-xs text-muted-foreground" for={`unit-${g.id}`}>Unidad</label>
                      <Input id={`unit-${g.id}`} name="unit" defaultValue={g.unit ?? ''} />
                    </div>
                    <div class="grid gap-1">
                      <label class="text-xs text-muted-foreground" for={`start-${g.id}`}>Inicio</label>
                      <Input id={`start-${g.id}`} name="startsAt" type="date" required defaultValue={toISODate(g.startsAt)} />
                    </div>
                    <div class="grid gap-1">
                      <label class="text-xs text-muted-foreground" for={`end-${g.id}`}>Fin</label>
                      <Input id={`end-${g.id}`} name="endsAt" type="date" defaultValue={g.endsAt ? toISODate(g.endsAt) : ''} />
                    </div>
                    <div class="flex justify-end sm:col-span-2">
                      <Button type="submit" variant="outline" size="sm">Actualizar</Button>
                    </div>
                  </form>
                </div>
              ))}
            </div>
          ) : (
            <p class="text-sm text-muted-foreground">Sin metas aún.</p>
          )}
        </CardContent>
      </Card>
    </div>

      <Card class="mt-6">
        <CardHeader>
          <CardTitle>Progreso de metas</CardTitle>
          <CardDescription>Seguimiento visual de tu avance</CardDescription>
        </CardHeader>
        <CardContent>
          <div class="grid gap-4 sm:grid-cols-2">
            {goals.filter(g => !g.endsAt || new Date(g.endsAt) >= new Date()).slice(0, 4).map((g) => {
              const target = g.targetValue != null ? Number(g.targetValue) : null;
              const isWeight = g.type === 'WEIGHT' && target != null;
              const currentWeight = isWeight ? latestWeight?.weightKg ?? null : null;
              const pct = isWeight && currentWeight != null ? Math.min(Math.round((currentWeight / target) * 100), 100) : null;
              return (
                <div class="rounded-lg border border-border/60 bg-background/30 p-4">
                  <p class="text-sm font-medium">{g.title}</p>
                  <p class="text-xs text-muted-foreground">{g.type}{g.unit ? ` (${g.unit})` : ''}</p>
                  <div class="mt-3">
                    <div class="flex items-baseline justify-between text-xs text-muted-foreground">
                      <span>Meta: {target ?? '—'}</span>
                      {isWeight && currentWeight != null ? <span>Actual: {formatNumber(currentWeight, { maximumFractionDigits: 1 })} kg</span> : null}
                    </div>
                    {pct != null ? (
                      <div class="mt-2 h-2 w-full overflow-hidden rounded-full bg-muted">
                        <div class="h-full rounded-full bg-primary transition-all" style={`width:${pct}%`} />
                      </div>
                    ) : null}
                  </div>
                </div>
              );
            })}
          </div>
          {goals.filter(g => !g.endsAt || new Date(g.endsAt) >= new Date()).length === 0 ? (
            <p class="text-sm text-muted-foreground">Crea metas activas para ver tu progreso aquí.</p>
          ) : null}
        </CardContent>
      </Card>
  </Shell>
</AppLayout>
