---
import AppLayout from '@/layouts/AppLayout.astro';
import { Card, CardContent, CardDescription, CardHeader, CardTitle } from '@/components/ui/card';
import { Button } from '@/components/ui/button';
import { Input } from '@/components/ui/input';
import { Label } from '@/components/ui/label';
import CsrfInput from '@/components/security/CsrfInput.astro';

const error = Astro.url.searchParams.get('error');
const sent = Astro.url.searchParams.get('sent');
---

<AppLayout title="GymTracker | Recuperar contraseña">
  <main class="relative">
    <div class="pointer-events-none absolute inset-0 -z-10 overflow-hidden">
      <div class="absolute -top-48 left-1/2 h-[620px] w-[620px] -translate-x-1/2 rounded-full bg-gradient-to-tr from-violet-500/20 via-sky-500/20 to-emerald-500/20 blur-3xl" />
    </div>

    <div class="mx-auto grid min-h-dvh max-w-md place-items-center px-4 py-10">
      <Card class="glass w-full">
        <CardHeader>
          <CardTitle class="text-2xl">Recuperar contraseña</CardTitle>
          <CardDescription>Te enviaremos un enlace para restablecerla.</CardDescription>
        </CardHeader>
        <CardContent>
          {sent ? <p class="mb-4 text-sm text-green-600 dark:text-green-400">Si el correo existe, recibirás un enlace de recuperación.</p> : null}
          {error === 'invalid' ? <p class="mb-4 text-sm text-destructive">Datos inválidos.</p> : null}
          {error === 'rate_limit' ? <p class="mb-4 text-sm text-destructive">Demasiados intentos. Intenta de nuevo en un minuto.</p> : null}
          <form method="post" action="/api/auth/forgot-password" class="grid gap-4">
            <CsrfInput />
            <div class="grid gap-2">
              <Label htmlFor="email">Correo electrónico</Label>
              <Input id="email" name="email" type="email" autoComplete="email" required />
            </div>
            <Button type="submit">Enviar enlace</Button>
            <p class="text-sm text-muted-foreground">
              <a class="underline underline-offset-4 hover:text-foreground" href="/login">Volver a inicio de sesión</a>
            </p>
          </form>
        </CardContent>
      </Card>
    </div>
  </main>
</AppLayout>
