---
import AppLayout from '@/layouts/AppLayout.astro';
import Shell from '@/components/shell/Shell.astro';
import { Card, CardContent, CardDescription, CardHeader, CardTitle } from '@/components/ui/card';
import { Button } from '@/components/ui/button';
import { Input } from '@/components/ui/input';
import { Label } from '@/components/ui/label';
import { Separator } from '@/components/ui/separator';
import CsrfInput from '@/components/security/CsrfInput.astro';
import { prisma } from '@/lib/db';
import { listRoutines } from '@/lib/workouts/queries';
import { ensureCsrfCookie, getCsrfFormValue } from '@/lib/security/csrf';

if (!Astro.locals.user) {
  return Astro.redirect('/login');
}

const error = Astro.url.searchParams.get('error');
const updated = Astro.url.searchParams.get('updated');
const deleted = Astro.url.searchParams.get('deleted');
const linked = Astro.url.searchParams.get('linked');
const imported = Astro.url.searchParams.get('imported');

const userId = Astro.locals.user.id;

const [exercises, routines] = await Promise.all([
  prisma.exercise.findMany({
    where: { userId },
    orderBy: { name: 'asc' },
    include: { _count: { select: { routineItems: true, setLogs: true } } }
  }),
  listRoutines(userId).catch(() => [])
]);

const csrfValue = getCsrfFormValue(ensureCsrfCookie(Astro.cookies));

function parseJson(str: string | null): string[] {
  if (!str) return [];
  try {
    const parsed = JSON.parse(str);
    return Array.isArray(parsed) ? parsed : [];
  } catch {
    return [];
  }
}
---

<AppLayout title="GymTracker | Ejercicios">
  <Shell title="Ejercicios" subtitle="Tu biblioteca de ejercicios">
    <div class="grid gap-4">
      {updated ? <p class="rounded-lg border border-green-500/30 bg-green-500/10 px-4 py-2 text-sm text-green-600 dark:text-green-400">Ejercicio actualizado.</p> : null}
      {deleted ? <p class="rounded-lg border border-green-500/30 bg-green-500/10 px-4 py-2 text-sm text-green-600 dark:text-green-400">Ejercicio eliminado.</p> : null}
      {linked ? <p class="rounded-lg border border-green-500/30 bg-green-500/10 px-4 py-2 text-sm text-green-600 dark:text-green-400">Ejercicio vinculado con WorkoutX.</p> : null}
      {imported ? <p class="rounded-lg border border-green-500/30 bg-green-500/10 px-4 py-2 text-sm text-green-600 dark:text-green-400">Ejercicio importado desde WorkoutX.</p> : null}
      {error === 'not_found' ? <p class="rounded-lg border border-destructive/30 bg-destructive/10 px-4 py-2 text-sm text-destructive">Ejercicio no encontrado.</p> : null}
      {error === 'workoutx_not_found' ? <p class="rounded-lg border border-destructive/30 bg-destructive/10 px-4 py-2 text-sm text-destructive">Ejercicio no encontrado en WorkoutX.</p> : null}

      <!-- Tabs -->
      <div class="flex gap-1 rounded-lg border border-border/60 bg-background/50 p-1">
        <button class="tab-btn flex-1 rounded-md px-3 py-1.5 text-sm font-medium transition-colors" data-tab="mine">
          Mis ejercicios
        </button>
        <button class="tab-btn flex-1 rounded-md px-3 py-1.5 text-sm font-medium text-muted-foreground transition-colors hover:text-foreground" data-tab="catalog">
          Biblioteca WorkoutX
        </button>
      </div>

      <!-- Mis ejercicios -->
      <div id="tab-mine" class="tab-content">
        {exercises.length ? (
          <div class="grid gap-3 sm:grid-cols-2 lg:grid-cols-3">
            {exercises.map((ex) => {
              const instructions = parseJson(ex.instructions);
              const secondaryMuscles = parseJson(ex.secondaryMuscles);
              return (
                <Card>
                  <CardHeader>
                    <CardTitle className="flex items-center gap-2">
                      {ex.name}
                      {ex.workoutxId ? <span class="inline-flex items-center rounded-full border border-primary/30 bg-primary/10 px-2 py-0.5 text-[10px] font-medium text-primary">WX</span> : null}
                    </CardTitle>
                    <CardDescription>
                      {[ex.muscle, ex.equipment].filter(Boolean).join(' · ') || 'Sin detalles'}
                    </CardDescription>
                  </CardHeader>
                  <CardContent>
                    <p class="mb-3 text-xs text-muted-foreground">
                      {ex._count.routineItems} rutinas · {ex._count.setLogs} series registradas
                    </p>

                    {ex.gifUrl ? (
                      <div class="mb-3 overflow-hidden rounded-lg bg-muted">
                        <img src={ex.gifUrl} alt={ex.name} class="w-full object-contain" loading="lazy" />
                      </div>
                    ) : null}

                    {instructions.length > 0 ? (
                      <div class="mb-3">
                        <p class="mb-1 text-xs font-medium">Instrucciones:</p>
                        <ol class="list-inside list-decimal space-y-0.5 text-xs text-muted-foreground">
                          {instructions.map((inst) => (
                            <li>{inst}</li>
                          ))}
                        </ol>
                      </div>
                    ) : null}

                    {secondaryMuscles.length > 0 ? (
                      <div class="mb-3 text-xs text-muted-foreground">
                        <span class="font-medium text-foreground">Músculos secundarios:</span>{' '}
                        {secondaryMuscles.join(', ')}
                      </div>
                    ) : null}

                    {ex.targetMuscle ? (
                      <div class="mb-3 text-xs text-muted-foreground">
                        <span class="font-medium text-foreground">Músculo objetivo:</span> {ex.targetMuscle}
                      </div>
                    ) : null}

                    <details class="group mb-2">
                      <summary class="cursor-pointer text-xs font-medium text-primary hover:underline">Añadir a rutina</summary>
                      <div class="mt-3">
                        <form method="post" action="/api/exercises/add-to-routine" class="grid gap-3">
                          <CsrfInput />
                          <input type="hidden" name="exerciseId" value={ex.id} />
                          <div class="grid gap-1">
                            <Label for={`existing-${ex.id}`}>Rutina existente</Label>
                            <select
                              id={`existing-${ex.id}`}
                              name="routineId"
                              class="h-9 rounded-md border border-input bg-background px-3 text-sm"
                            >
                              <option value="">— Elegir rutina —</option>
                              {routines.map((r) => (
                                <option value={r.id}>{r.name}</option>
                              ))}
                            </select>
                          </div>
                          <Separator class="my-1" />
                          <div class="grid gap-1">
                            <Label for={`new-name-${ex.id}`}>O crear nueva rutina</Label>
                            <Input id={`new-name-${ex.id}`} name="newRoutineName" placeholder="Nombre de la rutina" />
                          </div>
                          <div class="grid gap-1">
                            <Label for={`new-day-${ex.id}`}>Nombre del día</Label>
                            <Input id={`new-day-${ex.id}`} name="newDayName" placeholder="Día 1" />
                          </div>
                          <div class="grid grid-cols-2 gap-2">
                            <div class="grid gap-1">
                              <Label for={`sets-${ex.id}`}>Series</Label>
                              <Input id={`sets-${ex.id}`} name="targetSets" inputMode="numeric" placeholder="4" />
                            </div>
                            <div class="grid gap-1">
                              <Label for={`reps-${ex.id}`}>Reps</Label>
                              <Input id={`reps-${ex.id}`} name="targetReps" placeholder="8-12" />
                            </div>
                          </div>
                          <Button type="submit" size="sm" variant="secondary">Añadir</Button>
                        </form>
                      </div>
                    </details>

                    <details class="group">
                      <summary class="cursor-pointer text-xs text-muted-foreground hover:text-foreground">Editar</summary>
                      <div class="mt-3">
                        <form method="post" action="/api/exercises/update" class="grid gap-3">
                          <CsrfInput />
                          <input type="hidden" name="id" value={ex.id} />
                          <div class="grid gap-1">
                            <Label for={`name-${ex.id}`}>Nombre</Label>
                            <Input id={`name-${ex.id}`} name="name" required defaultValue={ex.name} />
                          </div>
                          <div class="grid grid-cols-2 gap-2">
                            <div class="grid gap-1">
                              <Label for={`muscle-${ex.id}`}>Músculo</Label>
                              <Input id={`muscle-${ex.id}`} name="muscle" defaultValue={ex.muscle ?? ''} />
                            </div>
                            <div class="grid gap-1">
                              <Label for={`equipment-${ex.id}`}>Equipo</Label>
                              <Input id={`equipment-${ex.id}`} name="equipment" defaultValue={ex.equipment ?? ''} />
                            </div>
                          </div>
                          <div class="flex gap-2">
                            <Button type="submit" size="sm" variant="secondary">Guardar</Button>
                            <form method="post" action="/api/exercises/delete">
                              <CsrfInput />
                              <input type="hidden" name="id" value={ex.id} />
                              <Button type="submit" size="sm" variant="ghost" class="text-destructive">Eliminar</Button>
                            </form>
                          </div>
                        </form>
                      </div>
                    </details>
                  </CardContent>
                </Card>
              );
            })}
          </div>
        ) : (
          <Card>
            <CardHeader>
              <CardTitle>Sin ejercicios</CardTitle>
              <CardDescription>Los ejercicios se crean automáticamente al importar rutinas o iniciar sesiones. También puedes explorar la Biblioteca WorkoutX para importar ejercicios.</CardDescription>
            </CardHeader>
          </Card>
        )}
      </div>

      <!-- Biblioteca WorkoutX -->
      <div id="tab-catalog" class="tab-content hidden">
        <div class="mb-4 flex items-center justify-between gap-2">
          <div class="flex items-center gap-2">
            <input
              id="wx-search-input"
              type="text"
              placeholder="Buscar en WorkoutX..."
              class="h-9 rounded-md border border-input bg-background px-3 text-sm w-56"
            />
            <button id="wx-search-btn" class="inline-flex h-9 items-center justify-center rounded-md bg-primary px-3 text-xs font-medium text-primary-foreground hover:bg-primary/90">
              Buscar
            </button>
          </div>
          <div class="flex items-center gap-2">
            <button id="wx-load-all-btn" class="inline-flex h-9 items-center justify-center rounded-md border border-primary/30 bg-primary/5 px-3 text-xs font-medium text-primary hover:bg-primary/10">
              Cargar todos
            </button>
            <button id="wx-browse-btn" class="inline-flex h-9 items-center justify-center rounded-md border border-input bg-background px-3 text-xs font-medium hover:bg-accent">
              Explorar todo
            </button>
          </div>
        </div>
        <div id="wx-loading" class="py-12 text-center text-sm text-muted-foreground">Cargando biblioteca...</div>
        <div id="wx-progress" class="hidden py-4 text-center text-xs text-muted-foreground"></div>
        <div id="wx-catalog" class="grid gap-3 sm:grid-cols-2 lg:grid-cols-3"></div>
        <div id="wx-empty" class="hidden py-12 text-center text-sm text-muted-foreground">Sin resultados.</div>
        <div id="wx-pagination" class="mt-4 flex items-center justify-center gap-3">
          <button id="wx-prev-btn" class="inline-flex h-8 items-center justify-center rounded-md border border-input bg-background px-3 text-xs font-medium hover:bg-accent disabled:opacity-40" disabled>
            Anterior
          </button>
          <span id="wx-page-info" class="text-xs text-muted-foreground"></span>
          <button id="wx-next-btn" class="inline-flex h-8 items-center justify-center rounded-md border border-input bg-background px-3 text-xs font-medium hover:bg-accent disabled:opacity-40" disabled>
            Siguiente
          </button>
        </div>
      </div>

      <!-- Detail modal -->
      <div id="wx-detail-overlay" class="fixed inset-0 z-50 hidden bg-black/60 backdrop-blur-sm">
        <div class="flex min-h-full items-center justify-center p-4">
          <div id="wx-detail-panel" class="max-h-[90vh] w-full max-w-2xl overflow-y-auto rounded-xl border border-border/60 bg-card p-6 shadow-2xl">
            <div id="wx-detail-loading" class="py-12 text-center text-sm text-muted-foreground">Cargando detalle...</div>
            <div id="wx-detail-content" class="hidden"></div>
          </div>
        </div>
      </div>
    </div>
  </Shell>
</AppLayout>

<script>
var CSRF_TOKEN = '{csrfValue}';
var WX_GIF_BASE = 'https://api.workoutxapp.com/v1/gifs/';

var tabBtns = document.querySelectorAll('.tab-btn');
tabBtns.forEach(function (btn) {
  btn.addEventListener('click', function () {
    tabBtns.forEach(function (b) {
      b.classList.remove('bg-primary/10', 'text-foreground', 'shadow-sm');
      b.classList.add('text-muted-foreground');
    });
    btn.classList.remove('text-muted-foreground');
    btn.classList.add('bg-primary/10', 'text-foreground', 'shadow-sm');
    document.querySelectorAll('.tab-content').forEach(function (el) {
      el.classList.add('hidden');
    });
    document.getElementById('tab-' + btn.dataset.tab).classList.remove('hidden');

    if (btn.dataset.tab === 'catalog') {
      loadCatalog(0);
    }
  });
});

tabBtns[0].classList.add('bg-primary/10', 'text-foreground', 'shadow-sm');

var wxOffset = 0;
var wxTotal = 0;
var wxLimit = 12;
var wxMode = 'browse';
var wxSearchTerm = '';
var wxAllExercises = [];
var wxLoadingAll = false;

function el(id) { return document.getElementById(id); }

function showLoading() {
  el('wx-loading').classList.remove('hidden');
  el('wx-catalog').innerHTML = '';
  el('wx-empty').classList.add('hidden');
  el('wx-progress').classList.add('hidden');
}

function hideLoading() {
  el('wx-loading').classList.add('hidden');
}

function renderCard(r) {
  var difficulty = r.difficulty ? r.difficulty.charAt(0).toUpperCase() + r.difficulty.slice(1) : '';
  var tags = r.movement_tags && r.movement_tags.length ? r.movement_tags.slice(0, 3).join(' · ') : '';
  var gifSrc = r.id ? WX_GIF_BASE + r.id : '';
  var img = gifSrc
    ? '<iframe src="' + gifSrc + '" class="w-full aspect-video" loading="lazy"></iframe>'
    : '';
  return '<div class="overflow-hidden rounded-lg border border-border/60 bg-card transition-all hover:shadow-md cursor-pointer wx-card" data-wx-id="' + r.id + '">' +
    (img ? '<div class="overflow-hidden bg-muted pointer-events-none">' + img + '</div>' : '') +
    '<div class="p-3 pointer-events-none">' +
      '<h3 class="truncate text-sm font-semibold">' + r.name + '</h3>' +
      '<p class="text-xs text-muted-foreground">' + r.target + ' · ' + r.equipment + '</p>' +
      (difficulty ? '<p class="text-xs text-muted-foreground">' + difficulty + (r.bodyPart ? ' · ' + r.bodyPart : '') + '</p>' : '') +
      (tags ? '<p class="mt-1 text-[10px] text-primary/70 truncate">' + tags + '</p>' : '') +
    '</div>' +
  '</div>';
}

function renderCards(data, append) {
  hideLoading();
  if (!data || !data.length) {
    if (!append) {
      el('wx-catalog').innerHTML = '';
      el('wx-empty').classList.remove('hidden');
    }
    return;
  }
  el('wx-empty').classList.add('hidden');
  if (append) {
    el('wx-catalog').insertAdjacentHTML('beforeend', data.map(renderCard).join(''));
  } else {
    el('wx-catalog').innerHTML = data.map(renderCard).join('');
  }
}

function updatePagination() {
  var page = Math.floor(wxOffset / wxLimit) + 1;
  var totalPages = Math.ceil(wxTotal / wxLimit);
  el('wx-page-info').textContent = 'Pagina ' + page + ' de ' + (totalPages || 1) + ' (' + wxTotal + ' ejercicios)';
  el('wx-prev-btn').disabled = wxOffset <= 0;
  el('wx-next-btn').disabled = wxOffset + wxLimit >= wxTotal;
}

async function loadCatalog(offset) {
  wxOffset = offset;
  showLoading();
  wxAllExercises = [];

  var url;
  if (wxMode === 'search' && wxSearchTerm) {
    url = '/api/workoutx/search?name=' + encodeURIComponent(wxSearchTerm);
  } else {
    url = '/api/workoutx/list?offset=' + wxOffset + '&limit=' + wxLimit;
  }

  try {
    var res = await fetch(url);
    if (!res.ok) {
      var errData = await res.json().catch(function () { return { error: 'Error de conexion' }; });
      throw new Error(errData.error || 'Error desconocido');
    }

    if (wxMode === 'search' && wxSearchTerm) {
      var results = await res.json();
      wxTotal = results.length;
      renderCards(results);
      el('wx-pagination').classList.add('hidden');
      el('wx-load-all-btn').classList.add('hidden');
    } else {
      var data = await res.json();
      wxTotal = data.total || 0;
      renderCards(data.data || []);
      el('wx-pagination').classList.remove('hidden');
      el('wx-load-all-btn').classList.remove('hidden');
      updatePagination();
    }
  } catch (err) {
    hideLoading();
    el('wx-catalog').innerHTML = '<p class="col-span-full py-8 text-center text-xs text-destructive">' + (err.message || 'Error al cargar') + '</p>';
  }
}

el('wx-prev-btn').addEventListener('click', function () {
  loadCatalog(Math.max(0, wxOffset - wxLimit));
});
el('wx-next-btn').addEventListener('click', function () {
  loadCatalog(wxOffset + wxLimit);
});

el('wx-search-btn').addEventListener('click', function () {
  var term = el('wx-search-input').value.trim();
  if (!term) return;
  wxMode = 'search';
  wxSearchTerm = term;
  loadCatalog(0);
});
el('wx-search-input').addEventListener('keydown', function (e) {
  if (e.key === 'Enter') el('wx-search-btn').click();
});

el('wx-browse-btn').addEventListener('click', function () {
  wxMode = 'browse';
  wxSearchTerm = '';
  el('wx-search-input').value = '';
  loadCatalog(0);
});

// Load all exercises (sequential batch fetch)
el('wx-load-all-btn').addEventListener('click', async function () {
  if (wxLoadingAll) return;
  wxLoadingAll = true;
  el('wx-load-all-btn').disabled = true;
  el('wx-load-all-btn').textContent = 'Cargando...';
  el('wx-pagination').classList.add('hidden');
  el('wx-progress').classList.remove('hidden');
  el('wx-progress').textContent = 'Iniciando carga de todos los ejercicios...';
  showLoading();
  wxAllExercises = [];

  try {
    // Get first page to know total
    var first = await fetch('/api/workoutx/list?offset=0&limit=10');
    if (!first.ok) throw new Error('Error al iniciar la carga');
    var firstData = await first.json();
    wxAllExercises = firstData.data || [];
    renderCards(wxAllExercises);
    wxTotal = firstData.total || 0;
    el('wx-progress').textContent = 'Cargados ' + wxAllExercises.length + ' de ' + wxTotal + ' ejercicios...';

    // Fetch remaining pages sequentially (respect rate limits)
    var pageSize = 10;
    var totalPages = Math.ceil(wxTotal / pageSize);

    for (var p = 1; p < totalPages; p++) {
      var off = p * pageSize;
      var resp = await fetch('/api/workoutx/list?offset=' + off + '&limit=' + pageSize);
      if (!resp.ok) {
        if (resp.status === 429) {
          // Rate limited — wait 2s and retry once
          await new Promise(function (r) { setTimeout(r, 2000); });
          resp = await fetch('/api/workoutx/list?offset=' + off + '&limit=' + pageSize);
          if (!resp.ok) throw new Error('Error al cargar página ' + (p + 1));
        } else {
          throw new Error('Error al cargar página ' + (p + 1));
        }
      }
      var pageData = await resp.json();
      var items = pageData.data || [];
      wxAllExercises = wxAllExercises.concat(items);
      renderCards(items, true);
      el('wx-progress').textContent = 'Cargados ' + wxAllExercises.length + ' de ' + wxTotal + ' ejercicios...';
    }

    el('wx-progress').textContent = 'Mostrando los ' + wxAllExercises.length + ' ejercicios disponibles.';
    el('wx-load-all-btn').textContent = 'Cargar todos';
    el('wx-load-all-btn').disabled = false;
    wxLoadingAll = false;
  } catch (err) {
    el('wx-progress').textContent = 'Error: ' + (err.message || 'Error desconocido');
    el('wx-load-all-btn').textContent = 'Cargar todos';
    el('wx-load-all-btn').disabled = false;
    wxLoadingAll = false;
  }
});

// Detail view - event delegation for close buttons
el('wx-catalog').addEventListener('click', function (e) {
  var card = e.target.closest('.wx-card');
  if (!card) return;
  var wxId = card.dataset.wxId;
  if (!wxId) return;
  openDetail(wxId);
});

el('wx-detail-overlay').addEventListener('click', function (e) {
  if (e.target === el('wx-detail-overlay') || e.target.getAttribute('data-action') === 'close-detail') {
    el('wx-detail-overlay').classList.add('hidden');
  }
});

// Delegate clicks inside detail content for close buttons
el('wx-detail-panel').addEventListener('click', function (e) {
  var closeBtn = e.target.closest('[data-action="close-detail"]');
  if (closeBtn) {
    el('wx-detail-overlay').classList.add('hidden');
  }
});

function openDetail(wxId) {
  el('wx-detail-loading').classList.remove('hidden');
  el('wx-detail-content').classList.add('hidden');
  el('wx-detail-content').innerHTML = '';
  el('wx-detail-overlay').classList.remove('hidden');

  fetch('/api/workoutx/search?id=' + wxId)
    .then(function (res) { return res.json(); })
    .then(function (d) {
      el('wx-detail-loading').classList.add('hidden');
      el('wx-detail-content').classList.remove('hidden');
      var instructions = d.instructions && d.instructions.length
        ? '<div class="mt-3"><p class="text-xs font-medium mb-1">Instrucciones:</p><ol class="list-inside list-decimal space-y-1 text-xs text-muted-foreground">' +
          d.instructions.map(function (inst) { return '<li>' + inst + '</li>'; }).join('') + '</ol></div>'
        : '';
      var secondary = d.secondaryMuscles && d.secondaryMuscles.length
        ? '<p class="text-xs text-muted-foreground"><span class="font-medium text-foreground">Secundarios:</span> ' + d.secondaryMuscles.join(', ') + '</p>'
        : '';
      var difficulty = d.difficulty ? d.difficulty.charAt(0).toUpperCase() + d.difficulty.slice(1) : '';
      var tags = d.movement_tags && d.movement_tags.length
        ? '<div class="mt-2 flex flex-wrap gap-1">' + d.movement_tags.map(function (t) {
            return '<span class="inline-flex items-center rounded-full border border-primary/20 bg-primary/5 px-2 py-0.5 text-[10px] text-primary">' + t + '</span>';
          }).join('') + '</div>'
        : '';
      var description = d.description
        ? '<p class="mt-3 text-xs text-muted-foreground leading-relaxed">' + d.description + '</p>'
        : '';

      el('wx-detail-content').innerHTML =
        '<div class="flex items-start justify-between gap-3">' +
          '<h2 class="text-lg font-bold">' + d.name + '</h2>' +
          '<button data-action="close-detail" class="shrink-0 rounded-md p-1 text-muted-foreground hover:bg-accent hover:text-foreground text-xl leading-none">&times;</button>' +
        '</div>' +
        '<div class="mt-1 flex flex-wrap gap-x-3 gap-y-0.5 text-xs text-muted-foreground">' +
          '<span><span class="font-medium text-foreground">Objetivo:</span> ' + (d.target || '-') + '</span>' +
          '<span><span class="font-medium text-foreground">Equipo:</span> ' + (d.equipment || '-') + '</span>' +
          '<span><span class="font-medium text-foreground">Parte:</span> ' + (d.bodyPart || '-') + '</span>' +
          (difficulty ? '<span><span class="font-medium text-foreground">Dificultad:</span> ' + difficulty + '</span>' : '') +
          (d.mechanic ? '<span><span class="font-medium text-foreground">Mecánica:</span> ' + d.mechanic + '</span>' : '') +
          (d.force ? '<span><span class="font-medium text-foreground">Fuerza:</span> ' + d.force + '</span>' : '') +
        '</div>' +
        (d.id ? '<div class="mt-4 overflow-hidden rounded-lg bg-muted"><iframe src="' + WX_GIF_BASE + d.id + '" class="w-full aspect-video"></iframe></div>' : '') +
        instructions +
        secondary +
        description +
        tags +
        '<form method="post" action="/api/workoutx/import" class="mt-5 flex gap-2">' +
          '<input type="hidden" name="csrf" value="' + CSRF_TOKEN + '" />' +
          '<input type="hidden" name="workoutxId" value="' + d.id + '" />' +
          '<button type="submit" class="flex-1 rounded-md bg-primary px-4 py-2 text-sm font-medium text-primary-foreground hover:bg-primary/90">Importar a mis ejercicios</button>' +
          '<button type="button" data-action="close-detail" class="rounded-md border border-input bg-background px-4 py-2 text-sm font-medium hover:bg-accent">Cerrar</button>' +
        '</form>';
    })
    .catch(function (err) {
      el('wx-detail-loading').classList.add('hidden');
      el('wx-detail-content').classList.remove('hidden');
      el('wx-detail-content').innerHTML = '<p class="py-8 text-center text-xs text-destructive">Error al cargar detalle: ' + (err.message || 'Error desconocido') + '</p>';
    });
}
</script>
