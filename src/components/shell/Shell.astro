---
import { Menu } from 'lucide-react';

import { LogoMark } from '@/components/icons';
import NavLink from '@/components/nav/NavLink.astro';
import { navItems } from '@/components/nav/nav';
import { ThemeToggle } from '@/components/theme/ThemeToggle';
import { Button } from '@/components/ui/button';
import CsrfInput from '@/components/security/CsrfInput.astro';

type Props = {
  title?: string;
  subtitle?: string;
};

const { title, subtitle } = Astro.props;
const user = Astro.locals.user;
---

<div class="min-h-dvh">
  <div class="mx-auto grid max-w-7xl grid-cols-1 gap-0 md:grid-cols-[260px_1fr]">
    <aside class="hidden md:sticky md:top-0 md:block md:h-dvh md:border-r md:border-border/60 md:bg-background/70 md:backdrop-blur">
      <div class="flex h-16 items-center gap-3 px-4">
        <div class="grid h-10 w-10 place-items-center rounded-xl border border-border/60 bg-card">
          <LogoMark className="h-6 w-6" />
        </div>
        <div class="leading-tight">
          <p class="text-sm font-semibold">GymTracker</p>
          <p class="text-xs text-muted-foreground">Progreso</p>
        </div>
      </div>
      <nav class="grid gap-1 px-3">
        {navItems.map((item) => <NavLink item={item} />)}
      </nav>
      <div class="mt-auto p-4 text-xs text-muted-foreground">
        <p class="opacity-80">Hecho para rendimiento y resultados.</p>
      </div>
    </aside>

    <div class="min-w-0">
      <header class="sticky top-0 z-20 border-b border-border/60 bg-background/70 backdrop-blur">
        <div class="flex h-16 items-center gap-3 px-4 sm:px-6">
          <button
            class="inline-flex h-10 w-10 items-center justify-center rounded-md border border-border/60 bg-background/40 text-foreground/90 md:hidden"
            aria-label="Abrir navegación"
          >
            <Menu className="h-5 w-5" />
          </button>
          <div class="min-w-0 flex-1">
            {title ? <p class="truncate text-sm font-semibold">{title}</p> : null}
            {subtitle ? <p class="truncate text-xs text-muted-foreground">{subtitle}</p> : null}
          </div>
          {user ? <p class="hidden text-xs text-muted-foreground sm:block">{user.email}</p> : null}
          <ThemeToggle client:load />
          <form method="post" action="/api/auth/logout">
            <CsrfInput />
            <Button type="submit" variant="outline" className="hidden sm:inline-flex">
              Salir
            </Button>
          </form>
        </div>
      </header>

      <div class="px-4 py-6 sm:px-6">
        <slot />
      </div>
    </div>
  </div>

  <!-- Mobile nav -->
  <div id="nav" class="fixed inset-0 z-40 hidden" role="dialog" aria-modal="true">
    <button class="absolute inset-0 bg-black/50 backdrop-blur-sm transition-opacity" aria-label="Cerrar navegación" onclick="document.getElementById('nav').classList.add('hidden')"></button>
    <div class="absolute left-0 top-0 h-full w-[78%] max-w-sm animate-in-from-left border-r border-border/60 bg-background shadow-2xl">
      <div class="flex h-16 items-center gap-3 px-4">
        <div class="grid h-10 w-10 place-items-center rounded-xl border border-border/60 bg-card">
          <LogoMark className="h-6 w-6" />
        </div>
        <div class="leading-tight">
          <p class="text-sm font-semibold">GymTracker</p>
          <p class="text-xs text-muted-foreground">Progreso</p>
        </div>
      </div>
      <nav class="grid gap-1 px-3">
        {navItems.map((item) => <NavLink item={item} />)}
      </nav>
    </div>
  </div>
</div>

<script>
  const nav = document.getElementById('nav');
  const toggle = document.querySelector('[aria-label="Abrir navegación"]');

  if (toggle && nav) {
    toggle.addEventListener('click', (e) => {
      e.preventDefault();
      nav.classList.remove('hidden');
    });

    nav.addEventListener('click', (e) => {
      if (e.target === nav) nav.classList.add('hidden');
    });

    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && !nav.classList.contains('hidden')) {
        nav.classList.add('hidden');
      }
    });
  }
</script>

<style>
  .animate-in-from-left {
    animation: slideIn 0.2s ease-out;
  }
  @keyframes slideIn {
    from { transform: translateX(-100%); }
    to { transform: translateX(0); }
  }
</style>
